  id                 String                   @id @unique @default(uuid())
  trackingCode       String                   @default("")
  name               String
  description        String                   @db.Text
  color              String
  phone              String                   @default("")
  validate_phone     Boolean                  @default(false)
  avatar             String?                  @default("")
  avatar_thumbnail   String?                  @default("")
  license            String?                  @default("")
  license_status     String                   @default("pending") // pending || approved || rejected
  status             String                   @default("inactive") // active || inactive
  score              Float                    @default(0) // 1 - 5
  total_score        Int                      @default(0)
  number_of_products Int                      @default(0) // 0
  number_of_sales    Int                      @default(0) // 0
  latitude           Float                    @default(0)
  longitude          Float                    @default(0)
  created_at         DateTime                 @default(now())
  approved_at        DateTime?
  rejected_at        DateTime?
  client             Client                   @relation(fields: [client_id], references: [id])
  client_id          Int
  province           Provinces                @relation(fields: [province_id], references: [id])
  province_id        Int
  city               Cities                   @relation(fields: [city_id], references: [id])
  city_id            Int
  category           MarketPlaceMainCategory? @relation(fields: [categoryId], references: [id])
  categoryId         String?
  products           StorefrontProducts[]
  StorefrontBookmark StorefrontBookmark[]
}

model StorefrontProducts {
  id              String                            @id @default(cuid())
  trackingCode    String
  title           String
  description     String
  score           Int                               @default(0)
  unitOfSales     String
  price           BigInt
  hasDiscount     Boolean                           @default(false)
  discountedPrice BigInt
  colors          String[]                          @default([])
  status          String                            @default("active")
  numberOfSales   Int                               @default(0)
  createdAt       DateTime                          @default(now())
  updatedAt       DateTime                          @default(now())
  storefront      Storefront                        @relation(fields: [storefrontId], references: [id])
  storefrontId    String
  category        MarketPlaceMainCategory           @relation(fields: [categoryId], references: [id])
  categoryId      String
  subCategory     MarketPlaceSubCategory            @relation(fields: [subCategoryId], references: [id])
  subCategoryId   String
  brand           MarketPlaceBrands                 @relation(fields: [brandId], references: [id])
  brandId         String
  features        MarketplaceProductFeatureValues[]
  files           MarketplaceMediaFiles[]
}

model MarketplaceMediaFiles {
  id          Int                 @id @default(autoincrement())
  type        String              @default("temp") // temp, normal
  thumbnail   String              @default("")
  file_name   String
  file_type   String // image, video
  sort_number Int                 @default(autoincrement())
  priority    String // primary, normal
  product     StorefrontProducts? @relation(fields: [productId], references: [id])
  productId   String?
}

model StorefrontBookmark {
  id           String     @id @default(cuid())
  client       Client     @relation(fields: [client_id], references: [id])
  client_id    Int
  storefront   Storefront @relation(fields: [storefrontId], references: [id])
  storefrontId String
}

// ********** DB Backups **********
model DbBackups {
  id        String   @id @default(cuid())
  filename  String
  userId    Int
  createdAt DateTime @default(now())
}

// MyCity
model MyCityModel {
  id              String                   @id @default(cuid())
  category        String
  title           String
  description     String                   @default("") @db.Text
  size            Int                      @default(0)
  year_built      Int                      @default(0)
  number_of_rooms Int                      @default(0)
  status          String                   @default("active") // pending, active, rejected
  renovation_tax  Boolean                  @default(false)
  latitude        Float                    @default(0)
  longitude       Float                    @default(0)
  province        Provinces                @relation(fields: [province_id], references: [id])
  province_id     Int
  city            Cities                   @relation(fields: [city_id], references: [id])
  city_id         Int
  created_at      DateTime                 @default(now())
  updated_at      DateTime                 @default(now())
  client          Client                   @relation(fields: [clientId], references: [id])
  clientId        Int
  media           MyCityMedia[]
  bookmarks       BookmarkMyCityLocation[]
}

model MyCityMedia {
  id          String       @id @default(cuid())
  tag         String       @default("file") // file, structural, architectural, facilities, crooky
  type        String       @default("temp") // temp, file
  file_name   String
  file_type   String       @default("image") // image, video, file
  sort_number Int          @default(autoincrement())
  priority    String       @default("normal") // primary, normal
  thumbnail   String?
  myCity      MyCityModel? @relation(fields: [myCityId], references: [id])
  myCityId    String?
}

model BookmarkMyCityLocation {
  id        String      @id @default(cuid())
  client    Client      @relation(fields: [client_id], references: [id])
  client_id Int
  myCity    MyCityModel @relation(fields: [myCityId], references: [id])
  myCityId  String
}

// save ads settings for recive notifications
