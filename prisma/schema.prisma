// Masters Model
model MastersCategories {
  id           String         @id @default(cuid())
  title        String
  status       String         @default("active") // active, inactive
  created_at   DateTime       @default(now())
  MastersModel MastersModel[]
}

model MastersModel {
  id                String                       @id @default(cuid())
  trackingCode      String
  is_verified_phone Boolean                      @default(false)
  score             Float                        @default(0) // 1-5
  total_score       Int                          @default(0)
  status            String                       @default("pending") // pending, active, inactive
  created_at        DateTime                     @default(now())
  updated_at        DateTime                     @default(now())
  category          MastersCategories            @relation(fields: [categoryId], references: [id])
  categoryId        String
  client            Client                       @relation(fields: [client_id], references: [id])
  client_id         Int
  province          Provinces                    @relation(fields: [province_id], references: [id])
  province_id       Int
  city              Cities                       @relation(fields: [city_id], references: [id])
  city_id           Int
  comments          MasterComments[]
  settings          MasterSettings[]
  words             MasterFilteredWords[]
  projects          MasterProjects[]
  verificationPhone MasterVerificationPhone[]
  reasons           ReasonsForRejectingMasters[]
  profile           MasterProfile?
  bookmarks         BookmarkMasters[]
}

model MasterProfile {
  id                 String       @id @default(cuid())
  fullname           String
  phone              String
  description        String       @db.Text
  national_code      BigInt       @default(0)
  postal_code        BigInt       @default(0)
  age                Int          @default(0)
  work_experience    Int          @default(0)
  national_code_img  String
  avatar             String
  avatar_thumbnail   String
  certificate        String?
  certificate_status String? // pending, approved, rejected
  master             MastersModel @relation(fields: [master_id], references: [id])
  master_id          String       @unique
}

model ReasonsForRejectingMasters {
  id        String       @id @default(cuid())
  text      String
  master    MastersModel @relation(fields: [master_id], references: [id])
  master_id String
}

model MasterSettings {
  id                      String       @id @default(cuid())
  comment_visibility      Boolean      @default(true)
  phone_number_visibility Boolean      @default(true)
  chat_feature_enabled    Boolean      @default(false)
  master                  MastersModel @relation(fields: [master_id], references: [id])
  master_id               String
}

model MasterFilteredWords {
  id        Int          @id @default(autoincrement())
  title     String
  master    MastersModel @relation(fields: [master_id], references: [id])
  master_id String
}

model MasterVerificationPhone {
  id         Int          @id @default(autoincrement())
  phone      String
  code       Int
  created_at DateTime     @default(now())
  master     MastersModel @relation(fields: [master_id], references: [id])
  master_id  String
}

model MasterProjects {
  id              String                      @id @default(cuid())
  title           String?
  description     String                      @db.Text
  exployer_number Int?
  master          MastersModel                @relation(fields: [master_id], references: [id])
  master_id       String
  files           MasterProjecFiles[]
  comments        MasterProjectComments[]
  likes           MasterProjectCommentLikes[]
  status          String                      @default("active") // active, inactive
  created_at      DateTime                    @default(now())
}

model MasterProjecFiles {
  id          Int             @id @default(autoincrement())
  tag         String          @default("file") // file, structural, architectural, facilities, crooky
  type        String          @default("temp") // temp, file
  file_name   String
  file_type   String          @default("image") // image, video, file
  sort_number Int             @default(autoincrement())
  priority    String          @default("normal") // primary, normal
  thumbnail   String?
  project     MasterProjects? @relation(fields: [project_id], references: [id])
  project_id  String?
}

model MasterComments {
  id          String       @id @default(cuid())
  comment     String       @default("")
  score       Float // 1-5
  status      String       @default("approved") // approved, rejected
  client      Client       @relation(fields: [client_id], references: [id])
  client_id   Int
  master      MastersModel @relation(fields: [master_id], references: [id])
  master_id   String
  created_at  DateTime     @default(now())
  approved_at DateTime     @default(now()) @updatedAt()
}

model MasterProjectComments {
  id          String         @id @default(cuid())
  comment     String         @default("")
  score       Float // 1-5
  status      String         @default("approved") // approved, rejected
  client      Client         @relation(fields: [client_id], references: [id])
  client_id   Int
  project     MasterProjects @relation(fields: [project_id], references: [id])
  project_id  String
  created_at  DateTime       @default(now())
  approved_at DateTime       @default(now()) @updatedAt()
}

model MasterProjectCommentLikes {
  id         String         @id @default(cuid())
  client     Client[]
  project    MasterProjects @relation(fields: [project_id], references: [id])
  project_id String
}

model BookmarkMasters {
  id        String       @id @default(cuid())
  client    Client       @relation(fields: [client_id], references: [id])
  client_id Int
  masters   MastersModel @relation(fields: [masterId], references: [id])
  masterId  String
}

// marketplace messenger
model MarketplaceMessengerHistory {
  id                Int      @id @default(autoincrement())
  key               String
  client_id         Int      @default(0)
  type              String   @default("starter") // starter, participant
  chat_type         String   @default("persoanl") // persoanl, storefront
  starter           Client   @relation("MarketplaceChatStarter", fields: [starter_id], references: [id])
  starter_id        Int
  participant       Client   @relation("MarketplaceChatParticipant", fields: [participant_id], references: [id])
  participant_id    Int
  status            String   @default("pending")
  last_message_time DateTime @default(now())
  created_at        DateTime @default(now())
}

model MarketplaceMessages {
  id            Int                   @id @default(autoincrement())
  client        Client                @relation(fields: [client_id], references: [id])
  client_id     Int
  key           String
  notification  Boolean               @default(false)
  type          String // video, voice, music, sticker, text, image, gif, doc
  content       String                @default("") // text, file url
  caption       String                @default("")
  seen          Boolean               @default(false)
  size          Int                   @default(0)
  length        Float                 @default(0)
  thumbnail     String                @default("")
  is_blocked    Boolean               @default(false)
  is_replied    Boolean               @default(false)
  is_edited     Boolean               @default(false)
  action_type   String                @default("normal") // normal, pin, mention, join, left, forward
  have_reaction Boolean               @default(false)
  is_deleted    Boolean               @default(false)
  reaction      String                @default("")
  created_at    DateTime              @default(now())
  received_at   DateTime?
  reply_to      MarketplaceMessages?  @relation("RepliesTo", fields: [reply_to_id], references: [id])
  reply_to_id   Int?                  @map("reply_to_id")
  replied_by    MarketplaceMessages[] @relation("RepliesTo")
}

model MarketplaceChatMessengerMessageDeleted {
  id         Int      @id @default(autoincrement())
  client_id  Int
  message_id Int
  chat_key   String
  created_at DateTime @default(now())
}
