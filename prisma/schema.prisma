// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RegisteredModel {
  id         Int       @id @default(autoincrement())
  phone      String
  code       Int
  created_at DateTime  @default(now())
  expires_at DateTime?
}

model validateClient {
  id         Int      @id @default(autoincrement())
  owner_id   Int
  type       String // advisor, estate_agent
  phone      String
  code       Int
  created_at DateTime @default(now())
}

model Client {
  id                              Int                            @id @default(autoincrement())
  webinar_provider_id             Int?
  name                            String                         @default("")
  score                           Int                            @default(0)
  surname                         String                         @default("")
  phone                           String                         @unique
  key                             String                         @default("")
  email                           String                         @default("")
  username                        String                         @default("")
  password                        String?                        @default("")
  type                            String                         @default("client")
  roles                           String[]                       @default(["client"]) // client && estate_agent
  avatar                          String?                        @default("")
  token                           String                         @default("")
  validate_email                  Boolean                        @default(false)
  status                          String                         @default("active")
  has_update_direct               Boolean                        @default(false) // direct_link
  has_update_cafebazar            Boolean                        @default(false) // cafebazar
  has_update_myket                Boolean                        @default(false) // myket
  has_update_google_play          Boolean                        @default(false) // google_play
  has_update_general_notification Boolean                        @default(true)
  created_at                      DateTime                       @default(now())
  updated_at                      DateTime                       @default(now())
  last_login_time                 DateTime                       @default(now())
  webinars                        Webinar[]
  installed_version               String                         @default("")
  contacts                        Contact[]
  real_state_agents               RealEstateAgents[]
  real_estate_agent_dmins         RealEstateAgentAdmins?
  event_rooms                     EventRooms[]
  event_groups                    EventGroups[]
  realEstate_ads                  RealEstateAds[]
  real_estate_agentComments       RealEstateAgentComments[]
  real_estate_advisor             RealEstateAdvisors?
  real_Estate_advisors_comments   RealEstateAdvisorsComments[]
  real_estate_chat_starter        ChatRealEstateHistory[]        @relation("ChatsStarter")
  real_estate_chat_participant    ChatRealEstateHistory[]        @relation("ChatsParticipant")
  messenger_starter               ChatMessengerHistory[]         @relation("MessengerStarter")
  messenger_participant           ChatMessengerHistory[]         @relation("MessengerParticipant")
  channel_real_estate_members     ChannelRealEstateMembers[]
  messenger_channles_members      MessengerChannlesMembers[]
  client_gifs                     clientGifs[]
  report_bugs                     ReportBugs[]
  province                        Provinces?                     @relation(fields: [provincesId], references: [id])
  city                            Cities?                        @relation(fields: [citiesId], references: [id])
  provincesId                     Int?                           @default(14)
  citiesId                        Int?                           @default(443)
  ReportViolations                ReportViolations[]
  ReferralCodes                   ReferralHistorry[]
  ChatMessengerMessages           ChatMessengerMessages[]
  MessengerGroupsMembers          MessengerGroupsMembers[]
  MessengerGroupsMessages         MessengerGroupsMessages[]
  HistoryOfScores                 HistoryOfScores[]
  BinstaAccounts                  BinstaAccounts[]
  ServicesComments                ServicesComments[]
  ServicesCommentLikes            ServicesCommentLikes[]
  DailyClientLogins               DailyClientLogins[]
  Storefront                      Storefront[]
  notification_tokens             clientNotificaionTokens[]
  ReceivePrizes                   ReceivePrizes[]
  MessengerChannels               MessengerChannels[]
  DailyMissionsLogs               DailyMissionsLogs[]
  MessengerChannelsMessages       MessengerChannelsMessages[]
  MessengerSaveMessageMessages    MessengerSaveMessageMessages[]
  myCity                          MyCityModel[]
  bookmarkCityLocations           BookmarkMyCityLocation[]
  ClientAdSettings                ClientAdSettings[]
  masterModel                     MastersModel[]
  masterComments                  MasterComments[]
  MasterProjectComments           MasterProjectComments[]
  MasterProjectCommentLikes       MasterProjectCommentLikes?     @relation(fields: [masterProjectCommentLikesId], references: [id])
  masterProjectCommentLikesId     String?
  BookmarkMasters                 BookmarkMasters[]
  MarketplaceMessages             MarketplaceMessages[]
  MarketplaceChatStarter          MarketplaceMessengerHistory[]  @relation("MarketplaceChatStarter")
  MarketplaceChatParticipant      MarketplaceMessengerHistory[]  @relation("MarketplaceChatParticipant")
  SuspiciousBehaviosForAds        SuspiciousBehaviosForAds[]
  FilteredNotification_Ads        FilteredNotification_Ads[]
  EstimatePriceAds                EstimatePriceAds[]
  StorefrontBookmark              StorefrontBookmark[]
}

model clientNotificaionTokens {
  id                 String   @id @unique @default(uuid())
  notification_token String
  device_info        String   @default("")
  client             Client   @relation(fields: [client_id], references: [id])
  client_id          Int
  created_at         DateTime @default(now())
}

model userNotificaionTokens {
  id                 String   @id @unique @default(uuid())
  notification_token String
  device_info        String   @default("")
  client             users    @relation(fields: [client_id], references: [id])
  client_id          Int
  created_at         DateTime @default(now())
}

model Operator_realEstateAgents {
  id         Int      @id @default(autoincrement())
  provinces  Int[]    @default([14])
  cities     Int[]    @default([443])
  created_at DateTime @default(now())
  client_id  Int
}

model clientGifs {
  id         Int      @id @default(autoincrement())
  file       String
  key        String
  client     Client   @relation(fields: [client_id], references: [id])
  client_id  Int
  created_at DateTime @default(now())
}

model ChatRealEstateHistory {
  id                Int      @id @default(autoincrement())
  client_id         Int      @default(0)
  chat_type         String   @default("persoanl") // persoanl, estate_agent
  type              String   @default("starter") // starter, participant
  starter           Client   @relation("ChatsStarter", fields: [starter_id], references: [id])
  starter_id        Int
  participant       Client   @relation("ChatsParticipant", fields: [participant_id], references: [id])
  participant_id    Int
  created_at        DateTime @default(now())
  last_message_time DateTime @default(now())
  key               String
  status            String   @default("pending")
}

model ChatRealEstateHistoryMessages {
  id             Int       @id @default(autoincrement())
  client_id      Int
  destination_id Int
  message_side   String    @default("") // starter, participant
  key            String?
  type           String // video, voice, music, sticker, text, image, gif, doc
  content        String    @default("") // text, file url
  caption        String    @default("")
  seen           Boolean   @default(false)
  mode           String    @default("normal") // normal, edited
  is_replied     Boolean   @default(false)
  reply_to_id    Int       @default(0)
  size           Int       @default(0)
  length         Float     @default(0)
  thumbnail      String    @default("")
  created_at     DateTime  @default(now())
  received_at    DateTime?
}

model ChannelRealEstateAgent {
  id                 Int                                @id @default(autoincrement())
  real_estate_agent  RealEstateAgents                   @relation(fields: [agent_id], references: [id])
  agent_id           Int                                @default(0)
  key                String
  last_message_time  DateTime                           @default(now())
  created_at         DateTime                           @default(now())
  type               String                             @default("normal") // normal, association
  priority           String                             @default("normal") // normal, high
  tag                String                             @default("normal") // normal, guard, fast
  number_of_messages Int                                @default(0)
  messages           ChannelRealEstateHistoryMessages[]
  members            ChannelRealEstateMembers[]
}

model ChannelRealEstateHistoryMessages {
  id          Int                    @id @default(autoincrement())
  key         String?
  type        String // video, voice, music, sticker, text, image, gif, doc
  content     String                 @default("") // text, file url
  caption     String                 @default("")
  mode        String                 @default("normal") // normal, edited
  is_replied  Boolean                @default(false)
  reply_to_id Int                    @default(0)
  size        Int                    @default(0)
  length      Float                  @default(0)
  thumbnail   String                 @default("")
  created_at  DateTime               @default(now())
  seen_number Int                    @default(0)
  channel     ChannelRealEstateAgent @relation(fields: [channel_id], references: [id])
  channel_id  Int
}

model ChannelRealEstateMembers {
  id                      Int                    @id @default(autoincrement())
  number_of_read_messages Int                    @default(0)
  client                  Client?                @relation(fields: [client_id], references: [id])
  client_id               Int?
  channel                 ChannelRealEstateAgent @relation(fields: [channel_id], references: [id])
  channel_id              Int
  created_at              DateTime               @default(now())
}

model Webinar {
  id             Int      @id @default(autoincrement())
  webinar_id     Int
  owner_id       Int?
  title          String
  description    String
  type           String
  event_link     String
  proceeding     String   @default("") @db.Text
  tag            String   @default("")
  status         String   @default("active")
  start_by_admin Int      @default(0)
  is_unlimited   Int      @default(1)
  guest_count    Int      @default(100)
  guest_access   Int      @default(0)
  created_at     DateTime @default(now())
  started_at     String
  start_time     String
  end_time       String
  year           Int?
  month          Int?
  client         Client[]
  guests         Guest[]
}

model Guest {
  id           Int     @id @default(autoincrement())
  client_id    Int?
  userid       Int?
  display_name String  @default("active")
  phone        String  @default("active")
  role         String  @default("active")
  webinar      Webinar @relation(fields: [webinar_id], references: [id])
  webinar_id   Int
}

model Contact {
  id           Int      @id @default(autoincrement())
  display_name String
  phone        String
  client       Client   @relation(fields: [client_id], references: [id])
  client_id    Int
  createdAt    DateTime @default(now())
}

model Logger {
  id             Int      @id @default(autoincrement())
  method         String?
  baseUrl        String?
  status_code    Int?
  content_length String?  @default("")
  response_time  String?
  user_agent     String?
  ip             String?
  created_at     DateTime @default(now())
}

model Slider {
  id         Int      @id @default(autoincrement())
  title      String
  thumbnail  String
  status     String   @default("active")
  tag        String   @default("home")
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
}

model Banners {
  id         Int      @id @default(autoincrement())
  title      String
  thumbnail  String
  url        String?
  status     String   @default("active")
  tag        String   @default("home")
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
}

model Provinces {
  id                 Int                @id @default(autoincrement())
  name               String
  slug               String
  cities             Cities[]
  real_estate_agents RealEstateAgents[]
  realEstate_ads     RealEstateAds[]
  clients            Client[]
  Storefront         Storefront[]
  MyCity             MyCityModel[]
  MastersModel       MastersModel[]
}

model Cities {
  id                 Int                @id @default(autoincrement())
  name               String
  slug               String
  province           Provinces          @relation(fields: [province_id], references: [id])
  province_id        Int
  real_estate_agents RealEstateAgents[]
  realEstate_ads     RealEstateAds[]
  clients            Client[]
  Storefront         Storefront[]
  myCity             MyCityModel[]
  MastersModel       MastersModel[]
}

model RealEstateAgents {
  id                       Int                       @id @default(autoincrement())
  tracking_code            String?
  name                     String
  phone                    String                    @default("")
  validate_phone           Boolean                   @default(false)
  avatar                   String?                   @default("")
  license                  String?                   @default("")
  license_status           String                    @default("pending") // pending || approved || rejected
  status                   String                    @default("inactive") // active || inactive
  score                    Float                     @default(0) // 1 - 5
  total_score              Int                       @default(0)
  number_of_ads            Int                       @default(0) // 0
  created_at               DateTime                  @default(now())
  approved_at              DateTime?
  client                   Client                    @relation(fields: [client_id], references: [id])
  client_id                Int
  province                 Provinces                 @relation(fields: [province_id], references: [id])
  province_id              Int
  city                     Cities                    @relation(fields: [city_id], references: [id])
  city_id                  Int
  real_estate_agent_admins RealEstateAgentAdmins[]
  comments                 RealEstateAgentComments[]
  real_estate_advisors     RealEstateAdvisors[]
  channels                 ChannelRealEstateAgent[]
  published_count          Int                       @default(autoincrement())
  approved_count           Int                       @default(0)
  rejected_count           Int                       @default(0)
  published_ad_time        DateTime                  @default(now())
}

model RealEstateAdvisors {
  id                   Int                               @id @default(autoincrement())
  tracking_code        String?
  phone                String                            @default("")
  validate_phone       Boolean                           @default(false)
  avatar               String?                           @default("")
  status               String                            @default("active") // active, inactive
  score                Int                               @default(0)
  total_score          Int                               @default(0)
  biography            String                            @default("")
  color                String                            @default("red")
  permissions          String[]                          @default([])
  comment_visibility   Boolean                           @default(false)
  number_of_ads        Int                               @default(0)
  total_customers      Int                               @default(0)
  keywords             String[]                          @default([])
  client               Client                            @relation(fields: [client_id], references: [id])
  client_id            Int                               @unique
  real_estate_agent    RealEstateAgents                  @relation(fields: [real_estate_agent_id], references: [id])
  real_estate_agent_id Int
  comments             RealEstateAdvisorsComments[]
  active_areas         RealEstateAdvisorsActiveAreas[]
  filtered_words       RealEstateAdvisorsFilteredWords[]
}

model RealEstateAdvisorsActiveAreas {
  id         Int                @id @default(autoincrement())
  title      String
  advisor    RealEstateAdvisors @relation(fields: [advisor_id], references: [id])
  advisor_id Int
}

model RealEstateAdvisorsFilteredWords {
  id         Int                @id @default(autoincrement())
  title      String
  advisor    RealEstateAdvisors @relation(fields: [advisor_id], references: [id])
  advisor_id Int
}

model RealEstateAdvisorsComments {
  id                  Int                @id @default(autoincrement())
  comment             String             @default("")
  score               Float // 1-5
  status              String             @default("approved") // pending, approved, rejected
  created_at          DateTime           @default(now())
  approved_at         DateTime           @default(now()) @updatedAt()
  client              Client             @relation(fields: [client_id], references: [id])
  client_id           Int
  real_estate_advisor RealEstateAdvisors @relation(fields: [advisor_id], references: [id])
  advisor_id          Int
}

model RealEstateAgentComments {
  id                Int              @id @default(autoincrement())
  comment           String           @default("")
  score             Float // 1-5
  status            String           @default("approved") // pending, approved, rejected
  client            Client           @relation(fields: [client_id], references: [id])
  client_id         Int
  real_estate_agent RealEstateAgents @relation(fields: [agent_id], references: [id])
  agent_id          Int
  created_at        DateTime         @default(now())
  approved_at       DateTime         @default(now()) @updatedAt()
}

model RealEstateAgentAdmins {
  id                Int              @id @default(autoincrement())
  client            Client           @relation(fields: [client_id], references: [id])
  client_id         Int              @unique
  real_estate_agent RealEstateAgents @relation(fields: [agent_id], references: [id])
  agent_id          Int
  color             String
  permissions       String[]         @default([])
  status            String           @default("active") // active, inactive
  categories        String[]         @default([])
  cities            String[]         @default([])
  created_at        DateTime         @default(now())
}

model EventRooms {
  id          Int              @id @default(autoincrement())
  webinar_id  Int
  owner_id    Int
  title       String
  type        String
  event_link  String
  guest_count Int              @default(0)
  tag         String           @default("")
  status      String           @default("active")
  created_at  DateTime         @default(now())
  clients     Client[]
  guests      EventRoomUsers[]
}

model EventRoomUsers {
  id            Int         @id @default(autoincrement())
  client_id     Int?
  userid        Int?
  display_name  String      @default("active")
  phone         String      @default("active")
  role          String      @default("active")
  event_room    EventRooms? @relation(fields: [event_room_id], references: [id])
  event_room_id Int?
}

model EventGroups {
  id         Int      @id @default(autoincrement())
  webinar_id Int
  owner_id   Int
  title      String
  event_link String
  tag        String   @default("")
  status     String   @default("active")
  created_at DateTime @default(now())
  clients    Client[]
}

model RealEstateAdItems {
  id                    Int                   @id @default(autoincrement())
  value                 String
  advertisement_setting RealEstateAdsSettings @relation(fields: [setting_id], references: [id])
  setting_id            Int
  advertisement         RealEstateAds         @relation(fields: [ad_id], references: [id])
  ad_id                 Int
}

model RealEstateAdsSettings {
  id          Int                 @id @default(autoincrement())
  field_name  String
  type        String // sale, presell, collaboration, rent
  is_active   Boolean             @default(true)
  required    Boolean             @default(true)
  field_type  String // input_string,input_number, list, toggle
  values      String[]            @default([])
  sort_number Int                 @default(autoincrement())
  status      String              @default("active") // active, inactive
  key         String              @default(uuid())
  items       RealEstateAdItems[]
  icon        String              @default("")
}

model RealEstateAdForm {
  id          String                    @id @default(cuid())
  title       String
  categories  RealEstateAdSubCategory[]
  description String                    @db.Text
  items       RealEstateAdFormItems[]
}

model RealEstateAdFormItems {
  id                       String                            @id @default(cuid())
  field_name               String
  is_active                Boolean                           @default(true)
  required                 Boolean                           @default(true)
  field_type               String // input_string,input_number, list, toggle
  values                   String[]                          @default([])
  sort_number              Int                               @default(autoincrement())
  status                   String                            @default("active") // active, inactive
  key                      String                            @default(uuid())
  form                     RealEstateAdForm                  @relation(fields: [form_id], references: [id])
  form_id                  String
  items                    RealEstateAdFormValue[]
  icon                     String                            @default("")
  filter_notification_list FilteredNotification_Ads_Values[]
}

model RealEstateAdFormValue {
  id            String                @id @default(cuid())
  value         String
  form          RealEstateAdFormItems @relation(fields: [form_id], references: [id])
  form_id       String
  advertisement RealEstateAds         @relation(fields: [ad_id], references: [id])
  ad_id         Int
}

model RealEstateAdMainCategory {
  id                      String                    @id @default(cuid())
  type                    String                    @default("sale") // sale, rent, participation, short_rent
  title                   String
  status                  String                    @default("active")
  RealEstateAdSubCategory RealEstateAdSubCategory[]
  RealEstateAds           RealEstateAds[]
}

model RealEstateAdSubCategory {
  id            String                   @id @default(cuid())
  title         String
  category      RealEstateAdMainCategory @relation(fields: [categoryId], references: [id])
  categoryId    String
  form          RealEstateAdForm?        @relation(fields: [formId], references: [id])
  formId        String?
  RealEstateAds RealEstateAds[]
}

model RealEstateAds {
  id            Int                       @id @default(autoincrement())
  tag           String                    @default("mr-building") // mr-building, divar
  category      RealEstateAdMainCategory? @relation(fields: [categoryId], references: [id])
  categoryId    String?
  subCategory   RealEstateAdSubCategory?  @relation(fields: [subCategoryId], references: [id])
  subCategoryId String?
  province      Provinces                 @relation(fields: [province_id], references: [id])
  province_id   Int
  city          Cities                    @relation(fields: [city_id], references: [id])
  city_id       Int
  status        String                    @default("pending") // pending, approved, rejected, active, inactive, invalidate, on_sale

  owner_name  String?
  owner_phone String?

  tracking_code              String
  seller_type                String    @default("individual") // individual || real_estate_agent, real_estate_advisor
  is_applicant               Boolean   @default(false)
  display_contact            Boolean   @default(true)
  title                      String?
  description                String?
  lat_item                   Float     @default(0)
  long_item                  Float     @default(0)
  year_built                 Int       @default(1300)
  size                       Int       @default(0)
  sale_price                 BigInt    @default(0)
  deposit_price              BigInt    @default(0)
  rent_price                 BigInt    @default(0)
  number_of_rooms            Int       @default(0)
  max_capicity               Int       @default(0)
  normal_days_price          BigInt    @default(0)
  weekend_price              BigInt    @default(0)
  special_days_price         BigInt    @default(0)
  cost_per_additional_person BigInt    @default(0)
  extra_people               Int       @default(0)
  price_status               String    @default("fair") // fair, high, low
  price_rating               Int       @default(3) // 1-5
  created_at                 DateTime  @default(now())
  approved_at                DateTime?
  rejected_at                DateTime?
  is_timed                   Boolean   @default(false)
  expired_at                 DateTime?
  client                     Client?   @relation(fields: [client_id], references: [id])
  client_id                  Int?
  agent_id                   Int       @default(0)
  advisor_id                 Int       @default(0)

  area                    String?
  agent_valuation_request Boolean @default(false)

  items        RealEstateAdItems[]
  robotAdItems RealEstateAdItems_sample_robotScraper[]
  media        RealEstateAdvertisements[]

  RealEstateAdForms        RealEstateAdFormValue[]
  Reasons                  ReasonsForRejectingAds[]
  ReasonsForDeletedAds     ReasonsForDeletedAds[]
  SuspiciousBehaviosForAds SuspiciousBehaviosForAds[]
  EstimatePriceAds         EstimatePriceAds[]
}

model EstimatePriceAds {
  id             String        @id @default(cuid())
  estimate_price String
  client         Client        @relation(fields: [clientId], references: [id])
  clientId       Int
  ad             RealEstateAds @relation(fields: [adId], references: [id])
  adId           Int
}

model RealEstateAdItems_sample_robotScraper {
  id            String         @id @default(cuid())
  field_name    String?
  value         String?
  icon          String?
  RealEstateAds RealEstateAds? @relation(fields: [ad_id], references: [id])
  ad_id         Int?
}

model ReasonsAdTemplate {
  id         String   @id @default(cuid())
  type       String   @default("rejected") // rejected, deleted
  text       String
  status     String   @default("active") // active, inactive
  userId     Int
  created_at DateTime @default(now())
}

model ReasonsForRejectingAds {
  id   String         @id @default(cuid())
  text String
  ad   RealEstateAds? @relation(fields: [adId], references: [id])
  adId Int?
}

model ReasonsForDeletedAds {
  id   String         @id @default(cuid())
  text String
  ad   RealEstateAds? @relation(fields: [adId], references: [id])
  adId Int?
}

model SuspiciousBehaviosForAds {
  id       String         @id @default(cuid())
  text     String
  ad       RealEstateAds? @relation(fields: [adId], references: [id])
  adId     Int?
  client   Client?        @relation(fields: [clientId], references: [id])
  clientId Int?
}

model RealEstateAdApproval {
  id         Int      @id @default(autoincrement())
  ad_id      Int
  user_id    Int
  user_type  String // dashboard_admin, app_admin, operator_estate_agent
  status     String   @default("approved") // approved, rejected
  text       String   @default("")
  created_at DateTime @default(now())
}

model RealEstateAdvertisements {
  id            Int           @id @default(autoincrement())
  file_name     String?
  file_type     String? // image, video
  sort_number   Int           @default(autoincrement())
  priority      String? // primary, normal
  thumbnail     String?
  advertisement RealEstateAds @relation(fields: [ad_id], references: [id])
  ad_id         Int
}

model RealEstateAdsTempFiles {
  id        Int     @id @default(autoincrement())
  file_type String
  file_name String
  thumbnail String?
}

model ForceUpdate {
  id                     Int      @id @default(autoincrement())
  installed_version_type String   @default("direct") // direct, cafebazar, myket
  title                  String   @default("")
  items                  String[] @default([])
  content                String   @default("") @db.Text
  file_name              String? // string || null
  indirect_link          String? // string || null
  version                String
  required               Boolean  @default(false)
